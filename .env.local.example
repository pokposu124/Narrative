# Finnhub API Key (required for news data)
# Get a free key at: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# Cron secret (optional but recommended)
# Set the same value in Vercel environment variables.
# Used to protect /api/cron and /api/trigger from unauthorised calls.
CRON_SECRET=change_this_to_a_random_string
